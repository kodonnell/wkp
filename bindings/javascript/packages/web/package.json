{
  "name": "@wkpjs/web",
  "version": "0.4.0",
  "wkpCoreCompatibility": "0.4.0",
  "description": "WebAssembly bindings for WKP core",
  "repository": {
    "type": "git",
    "url": "https://github.com/kodonnell/wkp.git"
  },
  "homepage": "https://github.com/kodonnell/wkp",
  "bugs": {
    "url": "https://github.com/kodonnell/wkp/issues"
  },
  "type": "module",
  "main": "src/index.js",
  "files": [
    "src",
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "node ./scripts/build-wasm.mjs",
    "clean": "node -e \"const fs=require('fs'); for (const f of ['dist/wkp_core.js','dist/wkp_core.wasm']) { if (fs.existsSync(f)) fs.unlinkSync(f); }\"",
    "benchmark": "node ./scripts/benchmark-node.mjs",
    "benchmark:serve": "node ./scripts/serve-benchmark.mjs",
    "test": "node --test ./tests/test-geometry-encoder.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}