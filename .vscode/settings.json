{
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda",
    "python-envs.pythonProjects": [],
    "python.analysis.extraPaths": [
        "bindings/python/src"
    ],
    "python.autoComplete.extraPaths": [
        "bindings/python/src"
    ],
    "python.analysis.exclude": [
        "**/.ignore/**"
    ],
    "search.exclude": {
        "**/.ignore": true
    },
    "files.exclude": {
        "**/.ignore": true
    },
    "cSpell.words": [
        "asarray",
        "ascontiguousarray",
        "boundscheck",
        "cdef",
        "cinit",
        "cpdef",
        "cython",
        "dtype",
        "elif",
        "geoms",
        "isinstance",
        "linearrings",
        "linestring",
        "linestrings",
        "malloc",
        "memcpy",
        "multilinestring",
        "multilinestrings",
        "multipoint",
        "multipoints",
        "multipolygon",
        "multipolygons",
        "prevs",
        "ssize",
        "staticmethod"
    ]
}